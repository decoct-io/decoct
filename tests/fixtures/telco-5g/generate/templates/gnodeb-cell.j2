# gNB Cell Configuration — {{ site }} / {{ sector }}
# SpectrumOne 5G RAN — {{ filename }}

cell_identity:
  cell_id: {{ cell_id }}
  pci: {{ pci }}
  tac: {{ tac }}
  site: "{{ site }}"
  sector: "{{ sector }}"
  plmn:
    mcc: "310"
    mnc: "260"

radio:
  frequency_band: "{{ frequency_band }}"
  center_frequency_mhz: {{ center_frequency_mhz }}
  bandwidth_mhz: {{ bandwidth_mhz }}
  duplex_mode: "{{ duplex_mode }}"
  subcarrier_spacing_khz: {{ scs_khz }}
  ssb_periodicity_ms: {{ ssb_periodicity_ms }}

antenna:
  tx_power_dbm: {{ tx_power_dbm }}
  antenna_tilt_deg: {{ antenna_tilt }}
  mimo_layers: {{ mimo_layers }}
{% if mimo_layers|int >= 64 %}
  antenna_type: "massive-mimo-64T64R"
  beamforming: "digital"
  beam_count: 8
{% elif mimo_layers|int >= 4 %}
  antenna_type: "panel-4T4R"
  beamforming: "analog"
  beam_count: 4
{% else %}
  antenna_type: "das-2T2R"
  beamforming: "none"
  beam_count: 1
{% endif %}

carrier:
  carrier_aggregation: {{ carrier_aggregation }}
{% if en_dc == 'true' %}
  en_dc: true
  sa: false
  nsa_anchor_band: "B2"
{% else %}
  en_dc: false
  sa: true
{% endif %}

scheduling:
  max_ue_per_tti: 16
  max_layers_dl: {{ mimo_layers }}
  max_layers_ul: {{ mimo_layers }}
  harq_processes: 16
  csi_reporting_interval_ms: 10

power_control:
  p0_nominal_pusch_dbm: -80
  alpha: 0.8
  closed_loop_index: 0
  tpc_accumulation: true

mobility:
  a3_offset_db: 3
  hysteresis_db: 1
  time_to_trigger_ms: 320
  s_intra_search_p: 62
  s_non_intra_search_p: 2

management:
  firmware_version: "{{ firmware_version }}"
  oam_password: "{{ oam_password }}"
  oam_port: 830
  oam_protocol: "netconf"
  logging_level: "info"

qos:
  default_5qi: 9
  supported_slices:
    - sst: 1
      sd: "000001"
    - sst: 1
      sd: "000002"
{% if sector == 'alpha' %}
    - sst: 2
      sd: "000010"
{% endif %}
{% if site.startswith('indoor-enterprise-02') %}
    - sst: 2
      sd: "000011"
{% endif %}
    - sst: 3
      sd: "000020"
