# gNB Distributed Unit Configuration — {{ site }}
# SpectrumOne 5G RAN — {{ filename }}

du_identity:
  du_id: "{{ du_id }}"
  site: "{{ site }}"
  status: "{{ status }}"
  plmn:
    mcc: "310"
    mnc: "260"

hardware:
  cpu_cores: {{ cpu_cores }}
  memory_gb: {{ memory_gb }}
  accelerator: "fpga-baseband"
  vendor: "SpectrumOne-RAN"
  model: "DU-5000"

fronthaul:
  ip: "{{ fronthaul_ip }}"
  vlan: {{ fronthaul_vlan }}
  bandwidth_gbps: {{ fronthaul_bandwidth_gbps }}
  protocol: "eCPRI"
  split_option: "7.2x"

timing:
  source: "{{ timing_source }}"
  sync_mode: "ptp"
  ptp_domain: 24
  holdover_hours: 4

connected_cells:
{% for cell in connected_cells %}
  - {{ cell }}
{% endfor %}

rlc:
  am_poll_retransmit_ms: 45
  am_max_retx_threshold: 8
  um_sn_field_length: 12
  t_reassembly_ms: 40

mac:
  scheduler: "proportional-fair"
  max_harq_tx: 8
  sr_periodicity_ms: 10
  bsr_timer_ms: 20
  phr_timer_ms: 100

management:
  firmware_version: "{{ firmware_version }}"
  oam_password: "{{ oam_password }}"
  oam_port: 830
  oam_protocol: "netconf"
  logging_level: "info"
  snmp_community: "public"

monitoring:
  kpi_reporting_interval_s: 15
  alarm_severity_filter: "warning"
  pm_counters_enabled: true
  trace_enabled: false
