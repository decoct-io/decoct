{
  "smf_id": "{{ smf_id }}",
  "smf_name": "{{ smf_name }}",
  "api_version": "{{ api_version }}",

  "plmn": {
    "mcc": "310",
    "mnc": "260"
  },

  "upf_associations": [
{% for upf in upf_associations %}
    {
      "upf_id": "{{ upf }}",
      "n4_ip": "10.100.3.{{ loop.index }}",
      "n4_port": 8805,
      "heartbeat_interval_s": 10,
      "status": "active"
    }{{ "," if not loop.last else "" }}
{% endfor %}
  ],

  "dnn_configs": [
{% for dnn in dnn_list %}
    {
      "dnn": "{{ dnn }}",
      "pdu_session_type": "{{ pdu_session_type }}",
      "ssc_mode": {% if dnn == 'ims' %}"SSC-Mode-1"{% elif dnn == 'enterprise' %}"SSC-Mode-3"{% else %}"SSC-Mode-1"{% endif %},
      "session_ambr": {
        "downlink_mbps": {{ session_ambr_dl_mbps }},
        "uplink_mbps": {{ session_ambr_ul_mbps }}
      },
{% if dnn == 'internet' %}
      "ipv4_pool": "10.200.0.0/16",
      "ipv6_prefix": "2001:db8:abcd::/48",
{% elif dnn == 'ims' %}
      "ipv4_pool": "10.201.0.0/16",
      "ipv6_prefix": "2001:db8:abce::/48",
{% elif dnn == 'iot' %}
      "ipv4_pool": "10.202.0.0/16",
      "ipv6_prefix": "2001:db8:abcf::/48",
{% else %}
      "ipv4_pool": "10.203.0.0/16",
      "ipv6_prefix": "2001:db8:abd0::/48",
{% endif %}
      "dns_primary": "10.100.5.1",
      "dns_secondary": "10.100.5.2"
    }{{ "," if not loop.last else "" }}
{% endfor %}
  ],

  "session_rules": {
    "max_pdu_sessions": 65536,
    "default_qos_5qi": 9,
    "default_arp_priority": 8,
    "pdu_session_inactivity_timer_s": 7200
  },

  "nf_profile": {
    "nf_status": "{{ nf_status }}",
    "nf_type": "SMF",
    "heartbeat_timer_s": 10,
    "nf_services": [
      "nsmf-pdusession",
      "nsmf-event-exposure"
    ]
  },

  "management": {
    "oam_password": "{{ oam_password }}",
    "oam_port": 443,
    "oam_protocol": "rest-api",
    "logging_level": "info",
    "audit_logging": true
  },

  "monitoring": {
    "kpi_reporting_interval_s": 15,
    "alarm_severity_filter": "warning",
    "pm_counters_enabled": true
  }
}
