{
  "link_id": "bh-link-01",
  "type": "backhaul",
  "endpoints": {
    "a": "cu-pool-north",
    "b": "core-dc-01"
  },
  "performance": {
    "bandwidth_gbps": 100,
    "latency_us": 1000,
    "jitter_us": 100,
    "packet_loss_rate": 1e-05
  },
  "transport": {
    "protocol": "IP/MPLS",
    "vlan": 2000,
    "encapsulation": "MPLS-VPN",
    "qos_marking": "AF41",
    "mtu": 1500
  },
  "security": {
    "ipsec_enabled": true,
    "ipsec_psk": "ipsec_psk_bh01_Ab3c",
    "ipsec_algorithm": "AES-256-GCM",
    "ike_version": 2
  },
  "monitoring": {
    "bfd_enabled": true,
    "bfd_interval_ms": 300,
    "oam_enabled": true,
    "pm_interval_s": 15
  },
  "redundancy": {
    "protection": "1+1",
    "switchover_ms": 50
  }
}
