# nginx site configuration — {{ pop }} {{ site_type }}
# ArcticCache CDN — {{ filename }}

worker_processes {{ worker_processes }};
worker_rlimit_nofile 65535;

events {
    worker_connections {{ worker_connections }};
    multi_accept on;
    use epoll;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # Logging
    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for" '
                    'rt=$request_time';

    access_log {{ access_log }} main;
    error_log {{ error_log }} warn;

    # Performance
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout {{ keepalive_timeout }};
    keepalive_requests 1000;
    client_max_body_size {{ client_max_body_size }};
    server_tokens off;

    # Gzip
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_min_length 256;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;

    # Rate limiting
    limit_req_zone $binary_remote_addr zone={{ rate_limit_zone }}:10m rate={{ rate_limit_rate }};

{% if site_type == 'static' %}
    # Cache path
    proxy_cache_path {{ cache_path }} levels=1:2 keys_zone=static_cache:100m max_size={{ cache_max_size }} inactive=24h use_temp_path=off;
{% endif %}
{% if site_type == 'api-proxy' %}

    upstream api_backend {
        server {{ upstream_host }}:{{ upstream_port }};
        keepalive 32;
    }
{% endif %}

    # SSL defaults
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # HTTPS server
    server {
        listen {{ ssl_port }} ssl http2;
        server_name {{ server_name }};

        ssl_certificate {{ ssl_certificate }};
        ssl_certificate_key {{ ssl_certificate_key }};

        # Security headers
        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
{% for hdr in extra_headers.split(';') %}
{% set parts = hdr.split(':') %}
        add_header {{ parts[0] }} "{{ parts[1] }}" always;
{% endfor %}

{% if site_type == 'static' %}
        location / {
            proxy_cache static_cache;
            proxy_cache_valid 200 24h;
            proxy_cache_valid 404 1m;
            proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
            proxy_cache_lock on;
            proxy_cache_lock_timeout 5s;

            root /var/www/static;
            index index.html;
            try_files $uri $uri/ =404;

            limit_req zone={{ rate_limit_zone }} burst=50 nodelay;

            expires 1d;
            add_header Cache-Control "public, immutable";
        }

        location /assets/ {
            alias /var/www/static/assets/;
            expires 30d;
            add_header Cache-Control "public, immutable";
{% if http2_push != 'none' %}
            http2_push {{ http2_push }};
{% endif %}
        }
{% endif %}
{% if site_type == 'api-proxy' %}
{% if api_key_header != 'none' %}
        # API authentication
        location / {
            proxy_set_header X-API-Key {{ api_key_header }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            proxy_pass {{ proxy_pass }};
            proxy_http_version 1.1;
            proxy_set_header Connection "";

            proxy_connect_timeout 5s;
            proxy_send_timeout 30s;
            proxy_read_timeout 30s;

            limit_req zone={{ rate_limit_zone }} burst=100 nodelay;
        }
{% endif %}

        location /health {
            access_log off;
            proxy_pass {{ proxy_pass }}/health;
            proxy_http_version 1.1;
        }

        location /metrics {
            access_log off;
            allow 10.0.0.0/8;
            deny all;
            proxy_pass {{ proxy_pass }}/metrics;
        }
{% endif %}
    }

    # HTTP redirect
    server {
        listen {{ listen_port }};
        server_name {{ server_name }};
        return 301 https://$host$request_uri;
    }
}
