# Palo Alto Firewall Configuration — {{ site }}
# Meridian Manufacturing — {{ filename }}

system:
  hostname: "{{ hostname }}"
  model: "{{ model }}"
  panos_version: "{{ panos_version }}"
  management:
    ip: "{{ mgmt_ip }}"
    netmask: 255.255.255.0
    default_gw: "{{ mgmt_ip.rsplit('.', 1)[0] }}.1"
  admin:
    password_hash: "{{ admin_password_hash }}"
  api_key: "{{ api_key }}"
  dns:
    primary: 10.4.1.10
    secondary: 10.4.1.11
  ntp:
    primary: 10.4.1.20
    secondary: 10.4.1.21
  domain: meridian-mfg.com
  timezone: America/Detroit
  logging:
    syslog:
      - server: 10.4.1.50
        port: 514
        facility: LOG_USER

zones:
{% for zone_str in zones %}
  - name: "{{ zone_str }}"
    type: layer3
{% if 'external' in zone_str or 'untrust' in zone_str %}
    protection_profile: strict
{% else %}
    protection_profile: default
{% endif %}
{% endfor %}

security_rules:
{% for rule_str in rules %}
{% set parts = rule_str.split(':') %}
  - name: "{{ parts[0] }}"
    action: "{{ parts[1] }}"
{% if parts | length > 2 %}
    application: any
    service: "tcp/{{ parts[2] }}"
{% else %}
    application: any
    service: any
{% endif %}
{% set src_dst = parts[0].split('-to-') %}
    source_zone: "{{ src_dst[0] }}"
    destination_zone: "{{ src_dst[1] }}"
    source_address: any
    destination_address: any
    log_start: false
    log_end: true
    log_forwarding: syslog-profile
{% endfor %}

nat_rules:
{% for nat_str in nat_rules %}
{% set parts = nat_str.split(':') %}
{% if parts[0] != 'none' %}
  - name: "{{ parts[0] }}"
    type: "{{ parts[1] }}"
{% if parts | length > 2 %}
    translated_address: "{{ parts[2] }}"
{% endif %}
{% endif %}
{% endfor %}

{% if gp_psk != 'none' %}
globalprotect:
  portal:
    enabled: true
    address: "{{ mgmt_ip }}"
  gateway:
    enabled: true
    pre_shared_key: "{{ gp_psk }}"
    tunnel_mode: ssl
    ip_pool_start: 10.100.0.1
    ip_pool_end: 10.100.0.254
    split_tunnel:
      include:
        - 10.0.0.0/8
      exclude:
        - 10.5.0.0/16
{% endif %}

threat_prevention:
  antivirus: enabled
  anti_spyware: enabled
  vulnerability: enabled
  file_blocking: enabled
  wildfire: enabled

ssl_decryption:
{% if 'hq' in site %}
  enabled: true
{% else %}
  enabled: false
{% endif %}
  ca_cert: /etc/paloalto/certs/decrypt-ca.pem
  exclude_categories:
    - financial-services
    - health-and-medicine

high_availability:
  mode: active-passive
  group_id: 1
  peer_ip: "{{ mgmt_ip.rsplit('.', 1)[0] }}.{{ mgmt_ip.rsplit('.', 1)[1] | int + 1 if mgmt_ip.rsplit('.', 1)[1] | int % 2 == 0 else mgmt_ip.rsplit('.', 1)[1] | int - 1 }}"
  heartbeat_interval: 1000
  preemptive: false
