{% if template_type == 'day0' %}
  "provisioning": {
    "auto_discover": true,
    "pnp_enabled": true,
    "image_distribution": {
      "golden_image": "cat9k_iosxe.17.09.04.SPA.bin",
      "compliance_check": true
    },
    "network_settings": {
      "dns_servers": ["10.4.1.10", "10.4.1.11"],
      "ntp_servers": ["10.4.1.20", "10.4.1.21"],
      "syslog_servers": ["10.4.1.50"],
      "aaa_servers": ["10.4.1.30", "10.4.1.31"],
      "domain_name": "meridian-mfg.com"
    },
    "fabric_settings": {
      "control_plane_nodes": 2,
      "border_nodes": 2,
      "edge_nodes": "auto",
      "multicast": "native",
      "l2_handoff": true
    }
  },
{% else %}
  "compliance": {
    "check_interval_hours": 24,
    "auto_remediate": false,
    "checks": [
      {"name": "ios-version", "expected": "17.9.4", "severity": "critical"},
      {"name": "ntp-configured", "expected": true, "severity": "high"},
      {"name": "syslog-configured", "expected": true, "severity": "high"},
      {"name": "aaa-radius", "expected": true, "severity": "critical"},
      {"name": "sda-fabric", "expected": true, "severity": "critical"},
      {"name": "snmp-community-rotated", "max_age_days": 90, "severity": "medium"},
      {"name": "ssh-only", "expected": true, "severity": "critical"}
