{
  "hostname": "app-server-01",
  "vendor": "dell",
  "model": "PowerEdge-R650",
  "rack": "r02",
  "management": {
    "ip_address": "10.4.9.13",
    "subnet_mask": "255.255.255.0",
    "gateway": "10.4.9.1",
    "interface": "iDRAC9",
    "username": "root",
    "password": "IPMI_@dm_app1_Qx4",
    "ipmi_over_lan": true,
    "virtual_console": "html5",
    "racadm_enabled": true
  },
  "firmware_version": "6.10.30.20",
  "snmp": {
    "community": "MrdnSNMP_bmc_RO",
    "trap_destination": "10.4.1.55",
    "version": "v2c"
  },
  "power": {
    "policy": "balanced",
    "cap_watts": 500,
    "redundancy": "redundant"
  },
  "thermal": {
    "fan_policy": "balanced",
    "exhaust_temp_max_c": 70,
    "inlet_temp_max_c": 35
  },
  "alerts": {
    "email": "noc@meridian-mfg.com",
    "smtp_server": "smtp.meridian-mfg.com",
    "smtp_port": 587,
    "severity_filter": [
      "critical",
      "warning"
    ],
    "snmp_traps": true
  },
  "storage": {
    "controller": "PERC-H755",
    "raid_level": "RAID10",
    "write_policy": "write-back",
    "read_policy": "adaptive-read-ahead"
  },
  "network_boot": {
    "pxe_enabled": true,
    "boot_order": [
      "hdd",
      "pxe",
      "cdrom"
    ]
  }
}
