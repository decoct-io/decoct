{
  "gateway_name": "vision-gw-01",
  "protocol": "ethernet-ip",
  "device_connection": {
    "host": "10.5.4.100",
    "port": 44818,
    "timeout_ms": 5000,
    "retries": 3
  },
  "poll_interval_ms": 1000,
  "registers": [
    {
      "address": "N7",
      "name": "0",
      "data_type": "CamStatus",
      "tag_path": "N7",
      "element_count": 1
    },
    {
      "address": "N7",
      "name": "1",
      "data_type": "DefectCount",
      "tag_path": "N7",
      "element_count": 1
    },
    {
      "address": "N7",
      "name": "2",
      "data_type": "InspRate",
      "tag_path": "N7",
      "element_count": 1
    }
  ],
  "mqtt": {
    "broker": "10.5.0.50",
    "port": 8883,
    "client_id": "vision-gw-01",
    "publish_token": "PLC_MQTT_Vis_Jk5",
    "tls": true,
    "topics": [
      "plant/vision/telemetry/status",
      "plant/vision/telemetry/defects"
    ],
    "qos": 1,
    "retain": false,
    "payload_format": "json",
    "timestamp_field": "ts",
    "batch_size": 10,
    "batch_interval_ms": 1000
  },
  "buffering": {
    "enabled": true,
    "max_size_mb": 50,
    "path": "/var/lib/plc-gateway/buffer"
  },
  "logging": {
    "level": "info",
    "file": "/var/log/plc-gateway/vision-gw-01.log"
  }
}
