{
  "broker_name": "cloud-bridge-01",
  "broker_type": "mosquitto",
  "listeners": {
    "tcp": {
      "bind": "0.0.0.0",
      "port": 1883,
      "max_connections": 100
    },
    "ssl": {
      "bind": "0.0.0.0",
      "port": 8883,
      "certfile": "/etc/mqtt/certs/server.pem",
      "keyfile": "/etc/mqtt/certs/server-key.pem",
      "cafile": "/etc/mqtt/certs/ca.pem",
      "key_password": "MQTT_TLS_Cloud_Ej7",
      "require_certificate": true,
      "tls_version": "tlsv1.2"
    }
  },
  "authentication": {
    "allow_anonymous": true,
    "token": "MQTT_Tk_Cloud_Vt6w",
    "password_file": "/etc/mqtt/passwd",
    "acl_file": "/etc/mqtt/acl"
  },
  "acl": [
    {
      "topic": "plant/+/telemetry/#",
      "access": "readwrite",
      "client_pattern": "plc-gw-*"
    },
    {
      "topic": "plant/+/command/#",
      "access": "write",
      "client_pattern": "edge-node-*"
    },
    {
      "topic": "plant/+/alert/#",
      "access": "readwrite",
      "client_pattern": "*"
    },
    {
      "topic": "$SYS/#",
      "access": "read",
      "client_pattern": "admin-*"
    }
  ],
  "bridge": {
    "enabled": true,
    "remote_host": "mqtt.meridian-mfg.com",
    "remote_port": 8883,
    "username": "plant-bridge",
    "password": "MQTT_Br1dge_Cloud_Bx5",
    "topics": [
      {
        "pattern": "plant/+/telemetry/#",
        "direction": "out",
        "qos": 1
      },
      {
        "pattern": "plant/+/alert/#",
        "direction": "out",
        "qos": 2
      },
      {
        "pattern": "plant/+/command/#",
        "direction": "in",
        "qos": 1
      }
    ],
    "keepalive": 60,
    "clean_session": false
  },
  "persistence": {
    "type": "file",
    "location": "/var/lib/mosquitto/mosquitto.db",
    "autosave_interval": 1800
  },
  "logging": {
    "level": "info",
    "destination": "file",
    "file": "/var/log/mqtt/broker.log",
    "max_size_mb": 100,
    "rotate_count": 5
  }
}
