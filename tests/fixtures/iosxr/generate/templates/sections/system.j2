!! IOS XR Configuration - {{ hostname }}
!! Generated: 2024-01-15 00:00:00 UTC
!! Platform: Cisco IOS-XR 7.9.2
!
hostname {{ hostname }}
!
logging console informational
logging monitor debugging
logging buffered 307200 debugging
logging trap informational
logging events link-status
logging source-interface Loopback0
logging {{ syslog_server }} vrf default severity info port default
!
! CUSTOM: NTP configuration
ntp
 server {{ ntp_server1 }}
 server {{ ntp_server2 }}
 source Loopback0
 update-calendar
!
! CUSTOM: DNS configuration
domain name-server {{ dns_server1 }}
domain name-server {{ dns_server2 }}
domain name lab.example.com
domain lookup disable
!
! CUSTOM: AAA configuration
aaa authentication login default group tacacs+ local
aaa authorization exec default group tacacs+ local
aaa authorization commands 15 default group tacacs+ local
aaa accounting exec default start-stop group tacacs+
aaa accounting commands 15 default start-stop group tacacs+
!
tacacs-server host {{ tacacs_key }} port 49
 key 7 {{ tacacs_key }}
!
! CUSTOM: SSH configuration
ssh server v2
ssh server rate-limit 60
ssh server logging
ssh timeout 30
!
! CUSTOM: SNMP configuration
snmp-server community {{ snmp_community }} RO
snmp-server community S3cr3tRW_c0mmunity RW
snmp-server trap-source Loopback0
snmp-server contact noc@example.com
snmp-server location {{ hostname }}-RACK
snmp-server enable traps snmp linkdown linkup
snmp-server enable traps bgp
snmp-server enable traps isis
snmp-server host 10.255.4.1 traps version 2c {{ snmp_community }}
!
service timestamps log datetime msec localtime show-timezone
service timestamps debug datetime msec localtime show-timezone
!
clock timezone UTC 0
!
control-plane
 management-plane
  inband
   interface all
    allow SSH
    allow SNMP
   !
  !
 !
!
line default
 exec-timeout 15 0
 session-timeout 15
 transport input ssh
!
