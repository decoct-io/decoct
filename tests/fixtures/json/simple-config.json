{
  "services": {
    "web": {
      "image": "nginx:1.25.3",
      "restart": "unless-stopped",
      "container_name": "test-web",
      "ports": [
        "192.0.2.10:80:80"
      ],
      "logging": {
        "driver": "json-file",
        "options": {
          "max-size": "10m",
          "max-file": "3"
        }
      }
    }
  }
}
