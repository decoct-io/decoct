# Kubernetes HorizontalPodAutoscaler — {{ service }} ({{ env }})
# WavePoint Financial — {{ filename }}
apiVersion: {{ api_version }}
kind: HorizontalPodAutoscaler
metadata:
  name: {{ service }}-hpa
  namespace: {{ namespace }}
  labels:
    app: {{ service }}
    env: {{ env }}
    team: platform
    part-of: wavepoint
  annotations:
    autoscaling.kubernetes.io/managed-by: gitops
{% if env == 'prod' %}
    wavepoint.io/oncall-team: payments-platform
{% endif %}
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{ service }}
  minReplicas: {{ min_replicas }}
  maxReplicas: {{ max_replicas }}
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: {{ cpu_target }}
{% if memory_target %}
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: {{ memory_target }}
{% endif %}
  behavior:
    scaleDown:
      stabilizationWindowSeconds: {{ scale_down_window }}
      policies:
        - type: Percent
          value: 25
          periodSeconds: 60
        - type: Pods
          value: 1
          periodSeconds: 60
      selectPolicy: Min
    scaleUp:
      stabilizationWindowSeconds: {{ scale_up_window }}
      policies:
        - type: Percent
          value: 50
          periodSeconds: 60
        - type: Pods
          value: 2
          periodSeconds: 60
      selectPolicy: Max
