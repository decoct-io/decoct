# Kubernetes ServiceAccount — {{ name }} ({{ env }})
# WavePoint Financial — {{ filename }}
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ name }}
  namespace: {{ namespace }}
  labels:
    app: {{ name }}
    env: {{ env }}
    team: platform
    part-of: wavepoint
{% for pair in labels_extra.split(';') %}
{% if pair and '=' in pair %}
{% set kv = pair.split('=', 1) %}
    {{ kv[0] }}: "{{ kv[1] }}"
{% endif %}
{% endfor %}
  annotations:
    eks.amazonaws.com/role-arn: {{ iam_role_arn }}
    serviceaccount.kubernetes.io/managed-by: gitops
{% if env == 'prod' %}
    wavepoint.io/last-audit: "2026-01-15"
    wavepoint.io/compliance: pci-dss
{% endif %}
automountServiceAccountToken: {{ automount_token }}
{% if env == 'prod' %}
secrets:
  - name: {{ name }}-token
imagePullSecrets:
  - name: registry-credentials
{% endif %}
