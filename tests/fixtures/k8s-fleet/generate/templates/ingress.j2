# Kubernetes Ingress — {{ name }} ({{ env }})
# WavePoint Financial — {{ filename }}
{% if env == 'staging' %}
apiVersion: networking.k8s.io/v1beta1
{% else %}
apiVersion: networking.k8s.io/v1
{% endif %}
kind: Ingress
metadata:
  name: {{ name }}-ingress
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ name }}-ingress
    env: {{ env }}
    team: platform
    part-of: wavepoint
  annotations:
    kubernetes.io/ingress.class: {{ ingress_class }}
{% if cluster_issuer %}
    cert-manager.io/cluster-issuer: {{ cluster_issuer }}
{% endif %}
{% if ssl_redirect == 'true' %}
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
{% endif %}
{% if rate_limit_rps %}
    nginx.ingress.kubernetes.io/limit-rps: "{{ rate_limit_rps }}"
    nginx.ingress.kubernetes.io/limit-burst-multiplier: "5"
{% endif %}
    nginx.ingress.kubernetes.io/proxy-body-size: "10m"
    nginx.ingress.kubernetes.io/proxy-read-timeout: "60"
    nginx.ingress.kubernetes.io/proxy-send-timeout: "60"
{% if env == 'prod' %}
    nginx.ingress.kubernetes.io/enable-modsecurity: "true"
    nginx.ingress.kubernetes.io/modsecurity-snippet: |
      SecRuleEngine On
      SecRule REQUEST_HEADERS:Content-Type "text/plain" "id:1,phase:1,deny,status:403"
    nginx.ingress.kubernetes.io/server-snippet: |
      more_set_headers "X-Frame-Options: DENY";
      more_set_headers "X-Content-Type-Options: nosniff";
      more_set_headers "Strict-Transport-Security: max-age=63072000";
{% endif %}
spec:
{% if cluster_issuer %}
  tls:
    - hosts:
        - {{ host }}
      secretName: {{ tls_secret }}
{% endif %}
  rules:
    - host: {{ host }}
      http:
        paths:
{% for path_rule in paths.split(';') %}
{% set parts = path_rule.split('=') %}
{% set backend = parts[1].split(':') %}
          - path: {{ parts[0] }}
            pathType: Prefix
            backend:
{% if env == 'staging' %}
              serviceName: {{ backend[0] }}
              servicePort: {{ backend[1] }}
{% else %}
              service:
                name: {{ backend[0] }}
                port:
                  number: {{ backend[1] }}
{% endif %}
{% endfor %}
