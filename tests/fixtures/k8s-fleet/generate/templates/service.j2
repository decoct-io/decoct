# Kubernetes Service — {{ service }} ({{ env }})
# WavePoint Financial — {{ filename }}
apiVersion: v1
kind: Service
metadata:
  name: {{ service }}
  namespace: {{ namespace }}
  labels:
    app: {{ service }}
    env: {{ env }}
    team: platform
    part-of: wavepoint
  annotations:
    service.kubernetes.io/topology-aware-hints: auto
{% if service_type == 'LoadBalancer' %}
    service.beta.kubernetes.io/aws-load-balancer-type: nlb
    service.beta.kubernetes.io/aws-load-balancer-scheme: internet-facing
    service.beta.kubernetes.io/aws-load-balancer-cross-zone-load-balancing-enabled: "true"
{% if env == 'prod' %}
    service.beta.kubernetes.io/aws-load-balancer-ssl-cert: arn:aws:acm:us-east-1:333333333333:certificate/abc-123-def
    service.beta.kubernetes.io/aws-load-balancer-ssl-ports: "443"
{% endif %}
{% endif %}
spec:
  type: {{ service_type }}
  selector:
    app: {{ service }}
    env: {{ env }}
{% if session_affinity != 'None' %}
  sessionAffinity: {{ session_affinity }}
  sessionAffinityConfig:
    clientIP:
      timeoutSeconds: 10800
{% else %}
  sessionAffinity: None
{% endif %}
{% if service_type == 'LoadBalancer' and external_traffic_policy %}
  externalTrafficPolicy: {{ external_traffic_policy }}
{% if health_check_port %}
  healthCheckNodePort: {{ health_check_port }}
{% endif %}
{% endif %}
  ports:
    - name: http
      protocol: {{ protocol }}
      port: {{ service_port }}
      targetPort: {{ target_port }}
{% if env == 'prod' or env == 'staging' %}
    - name: metrics
      protocol: TCP
      port: 9090
      targetPort: 9090
{% endif %}
